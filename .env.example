# ─── 必需配置 ───────────────────────────
# Telegram Bot Token（找 @BotFather 创建机器人获取）
BOT_TOKEN=1234567890:ABCdefGHIjklMNOpqrsTUVwxyz

# Telegram 群/频道 ID（把机器人拉进群后获取）
GROUP_ID=-1001234567890

# ─── 可选配置 ───────────────────────────
# 管理员密码（管理面板登录用，默认 admin888）
ADMIN_PASSWORD=请修改此密码

# 代理地址（国内服务器需要，用于访问 Telegram API）
PROXY_URL=http://127.0.0.1:7897

# 服务端口（默认 3000）
PORT=3000
